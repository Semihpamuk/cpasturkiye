# ─────────────────────────────────────────────────────────────────────────────
# Admin Paneli (/admin)
# ─────────────────────────────────────────────────────────────────────────────
# Production'da MUTLAKA değiştir — varsayılan değer güvensizdir
ADMIN_PASSWORD=guclu-bir-sifre-sec
ADMIN_SECRET=en-az-32-karakter-rastgele-bir-string-gir

# ─────────────────────────────────────────────────────────────────────────────
# iyzico Ödeme Altyapısı
# Sandbox: https://sandbox.iyzipay.com → API Keys bölümünden al
# Production: https://merchant.iyzipay.com → API Keys bölümünden al
# ─────────────────────────────────────────────────────────────────────────────
IYZICO_API_KEY=sandbox-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
IYZICO_SECRET_KEY=sandbox-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox test için: https://sandbox-api.iyzipay.com
# Production için:   https://api.iyzipay.com
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ─────────────────────────────────────────────────────────────────────────────
# E-posta (SMTP) — Sipariş bildirimleri ve müşteri onay e-postaları için
# Gmail örneği: SMTP_HOST=smtp.gmail.com, PORT=587, SMTP_USER=hesap@gmail.com
# Uygulama şifresi: https://myaccount.google.com/apppasswords
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@cpasturkiye.com
SMTP_PASS=uygulamasifreniziburayin

# ─────────────────────────────────────────────────────────────────────────────
# Site Bilgileri (iyzico başvurusu ve yasal uyumluluk için)
# NEXT_PUBLIC_ prefix'li değişkenler tarayıcıya da gönderilir — hassas veri koyma
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_PHONE=+90 (212) 000 00 00
NEXT_PUBLIC_SITE_MERSIS=0000000000000000
NEXT_PUBLIC_SITE_TAX_OFFICE=Maslak Vergi Dairesi
NEXT_PUBLIC_SITE_TAX_ID=0000000000
# KEP adresi: Kayıtlı Elektronik Posta — iyzico başvurusunda zorunludur
NEXT_PUBLIC_SITE_KEP=jale@hs01.kep.tr
